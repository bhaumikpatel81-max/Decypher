{
  "manifest_version": 2,
  "name": "Decypher Scout",
  "version": "1.0.0",
  "description": "Capture candidate profiles from any job portal into Decypher",
  "applications": {
    "gecko": {
      "id": "decypher-scout@decypher.app",
      "strict_min_version": "125.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "downloads"
  ],
  "background": {
    "scripts": ["background/background.firefox.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.naukri.com/*",
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.foundit.in/*",
        "https://*.iimjobs.com/*",
        "https://*.monster.com/*",
        "https://*.shine.com/*"
      ],
      "js": ["content/content-main.js"],
      "css": ["content/styles/scout-ui.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/scout-16.svg",
      "32": "icons/scout-32.svg",
      "48": "icons/scout-48.svg",
      "128": "icons/scout-128.svg"
    }
  },
  "icons": {
    "16": "icons/scout-16.svg",
    "48": "icons/scout-48.svg",
    "128": "icons/scout-128.svg"
  }
}
